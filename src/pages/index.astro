---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft).catch(() => []))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="Peculiar Peach — For Neurodivergent People"
  description="A space for ADHD, autistic, AuDHD, and neurodivergent people. Resources, articles, a glossary, and merch that gets it."
  image="/og-default.svg"
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator fullHeight>
    <Badge slot="badge" variant="brand" pill pulse>ADHD · Autism · AuDHD · and more</Badge>

    <h1 slot="title" class="!text-[clamp(2rem,11.2vw,3rem)] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span style="color: #ffbe72; -webkit-text-fill-color: #ffbe72;">Weird brains,</span><br />
      <span class="text-foreground">welcome home.</span>
    </h1>

    <p slot="description" class="text-brand-300">
      Peculiar Peach is a space for neurodivergent people — ADHD, autistic, AuDHD, dyslexic, and every flavor in between. Resources, articles, and a whole lot of we-get-it energy.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="/resources">
        Find Resources
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/blog">
        <Icon name="book-open" size="sm" />
        Read Articles
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- What we are -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>What's here</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Built for brains like yours
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          No clinical-speak. No inspiration-poster energy. Just honest, useful stuff for people whose brains run a little differently.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        <Card hover href="/resources" class="group flex flex-col" data-reveal>
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="book-open" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Resources</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Curated tools, guides, and crisis support — organized so you can actually find things when your brain is in full chaos mode.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Explore resources
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>

        <Card hover href="/glossary" class="group flex flex-col" data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="search" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Glossary</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Plain-language definitions for the terms you keep seeing — ADHD, AuDHD, masking, stimming, RSD, and more. No medical degree required.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                See all terms
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>

        <Card hover href="/shop" class="group flex flex-col" data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="shopping-bag" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Shop</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Merch that says the quiet part loud. Wear your brain on your sleeve — literally.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Browse the shop
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Articles -->
  {posts.length > 0 && (
    <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
        <div class="flex flex-col items-center gap-6 text-center" data-reveal>
          <Badge variant="brand" pill>Latest articles</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Fresh from the blog
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={`/blog/${post.id.replace('en/', '')}`}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              author={post.data.author}
              image={post.data.image}
              svgSlug={post.data.svgSlug}
            />
          ))}
        </div>

        <div class="flex justify-center">
          <Button variant="outline" href="/blog">
            All articles
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </section>
  )}

  <!-- About teaser -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <div class="flex flex-col justify-center sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 mb-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">About us</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Peculiar is not<br />
              <span class="text-brand-400">an insult.</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty mb-4 sm:max-w-xl glitch:max-w-none">
            We reclaimed it. Peculiar Peach exists because neurodivergent people deserve a space that doesn't talk down to them, pathologize their existence, or make them feel broken.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty mb-8 sm:max-w-xl glitch:max-w-none sm:hidden glitch:block">
            You're not broken. You're running different software — and honestly, some of it is incredible.
          </p>
          <Button variant="outline" href="/about" class="self-start sm:self-center glitch:self-start sm:hidden glitch:inline-flex">
            Our story
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <div class="grid grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="brain" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">ADHD</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="sparkles" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Autism</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="zap" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">AuDHD</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="heart" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">& Everyone Else</p>
            </div>
          </div>
        </Card>
        <div class="hidden sm:flex justify-center glitch:hidden" data-reveal data-reveal-delay="2">
          <Button variant="outline" href="/about">
            Our story
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Newsletter</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Words for weird brains.
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Articles, resources, and the occasional unhinged observation — delivered to your inbox when we feel like it (which, ADHD permitting, is pretty regularly).
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://peculiarpeach.substack.com" class="cta-btn-brand">
          Subscribe on Substack
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          Learn more
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <LetterGlitchBand>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Words for weird brains.
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Articles, resources, and the occasional unhinged observation — delivered to your inbox when we feel like it (which, ADHD permitting, is pretty regularly).
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://peculiarpeach.substack.com" class="hero-btn-brand">
          Subscribe on Substack
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          Learn more
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>
</LandingLayout>
